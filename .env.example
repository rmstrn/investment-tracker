# ---------------------------------------------------------------------------
# Root-level .env — shared variables. Copy to .env.local and fill in.
# App-specific .env files live in apps/*/.env.example.
# In production, these are provisioned via Doppler (see README.md).
# ---------------------------------------------------------------------------

# Core URLs (defaults for local dev via docker-compose)
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
AI_URL=http://localhost:8000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://investment:investment@localhost:5432/investment_dev?sslmode=disable

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379/0

# Clerk — use dev-instance keys from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Sentry — create projects at https://sentry.io (one per app)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=rmstrn
SENTRY_AUTH_TOKEN=

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Market data (will be used from TASK_04 onwards)
POLYGON_API_KEY=
COINGECKO_API_KEY=

# Brokers (TASK_06)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# LLM
ANTHROPIC_API_KEY=

# Envelope encryption KEK — generate locally with: openssl rand -base64 32
# In prod: AWS KMS key ARN instead
CREDENTIALS_KEK_BASE64=
