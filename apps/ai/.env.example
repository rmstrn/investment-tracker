# apps/ai — Python FastAPI service
# Copy to .env.local for local dev.

ENVIRONMENT=development
AI_LISTEN_HOST=0.0.0.0
AI_LISTEN_PORT=8000

# Postgres (shared with api — same DB for vector embeddings via pgvector)
DATABASE_URL=postgres://investment:investment@localhost:5432/investment_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/1

# LLM
ANTHROPIC_API_KEY=

# Core API — tool calls round-trip through it
CORE_API_URL=http://localhost:8080
CORE_API_INTERNAL_TOKEN=

# Sentry
SENTRY_DSN=
