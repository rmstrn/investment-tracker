# apps/api — Go server environment
# Copy to .env.local for local dev.

API_LISTEN_ADDR=:8080

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://investment:investment@localhost:5432/investment_dev?sslmode=disable

# Redis (asynq queue + cache)
REDIS_URL=redis://localhost:6379/0

# Clerk — dev instance
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWT_ISSUER=https://REPLACE.clerk.accounts.dev

# External APIs
POLYGON_API_KEY=
COINGECKO_API_KEY=
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Envelope encryption KEK (base64, 32 bytes). Dev only; prod uses AWS KMS.
# Generate: openssl rand -base64 32
CREDENTIALS_KEK_BASE64=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# AI service address (internal)
AI_SERVICE_URL=http://localhost:8000
