# apps/api — Go server environment.
# Copy to .env.local for local dev; secrets in prod live in Doppler.

# ── Server ─────────────────────────────────────────────────────────────
API_LISTEN_ADDR=:8090
ENV=development
SHUTDOWN_TIMEOUT=15s

# ── Observability ──────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=          # "json" or "console"; blank = auto-pick from ENV
SENTRY_DSN=

# ── Data stores (docker-compose defaults) ──────────────────────────────
DATABASE_URL=postgres://investment:investment@localhost:5432/investment_dev?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# ── Clerk ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWKS_URL=https://REPLACE.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Stripe (billing) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── AI service (internal) ──────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=REPLACE_ME_INTERNAL_TOKEN

# ── Market data ────────────────────────────────────────────────────────
POLYGON_API_KEY=
COINGECKO_API_KEY=          # optional — free tier works without

# ── Broker aggregation (SnapTrade) ─────────────────────────────────────
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ── Envelope encryption KEK ────────────────────────────────────────────
# 32-byte AES-256 key, base64-encoded. Dev only — prod uses AWS KMS.
# Generate: openssl rand -base64 32
ENCRYPTION_KEK=
