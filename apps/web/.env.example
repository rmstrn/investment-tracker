# apps/web — Next.js environment
# Copy to .env.local for local dev. `NEXT_PUBLIC_*` are exposed to the browser.

APP_URL=http://localhost:3000
API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Clerk (dev instance)
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Chart backend (Phase β.1 migration switch)
# `recharts` (default) — current Recharts-backed chart kinds.
# `primitives` — custom SVG primitives layer. Currently affects Sparkline
#                + DonutChart; other kinds (Line/Area/Bar/Calendar/Treemap)
#                stay on Recharts until later phases.
NEXT_PUBLIC_PROVEDO_CHART_BACKEND=recharts
