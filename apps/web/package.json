{
  "name": "@investment-tracker/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.17.2",
    "@clerk/nextjs": "^6.16.0",
    "@investment-tracker/api-client": "workspace:*",
    "@investment-tracker/design-tokens": "workspace:*",
    "@investment-tracker/shared-types": "workspace:*",
    "@investment-tracker/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "geist": "^1.3.1",
    "lucide-react": "^0.468.0",
    "next": "^15.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@investment-tracker/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@axe-core/playwright": "^4.10.2",
    "axe-core": "^4.11.3",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
