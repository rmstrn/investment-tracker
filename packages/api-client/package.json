{
  "name": "@investment-tracker/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Typed fetch client for the Investment Tracker API. Wraps openapi-fetch on top of @investment-tracker/shared-types.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@investment-tracker/shared-types": "workspace:*",
    "@investment-tracker/ui": "workspace:^",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
