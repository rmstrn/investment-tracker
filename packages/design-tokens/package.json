{
  "name": "@investment-tracker/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Source-of-truth design tokens for Portfolio. Compiled via Style Dictionary to Tailwind (web), Swift (iOS), and CSS custom properties.",
  "main": "build/js/tokens.js",
  "types": "build/js/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./build/js/tokens.d.ts",
      "default": "./build/js/tokens.js"
    },
    "./css": "./build/css/tokens.css",
    "./tailwind": {
      "types": "./build/tailwind/tokens.d.ts",
      "default": "./build/tailwind/tokens.js"
    },
    "./theme.css": "./build/tailwind/theme.css",
    "./animations.css": "./animations.css",
    "./brand": {
      "types": "./build/js/brand.d.ts",
      "default": "./build/js/brand.js"
    }
  },
  "files": ["build", "tokens", "animations.css"],
  "scripts": {
    "build": "node build.js",
    "prepare": "node build.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "node build.js",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "node -e \"import('node:fs/promises').then(f => f.rm('build', {recursive: true, force: true}))\""
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0"
  }
}
