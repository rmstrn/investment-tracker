{
  "motion": {
    "duration": {
      "instant": {
        "$value": "80ms",
        "$type": "duration",
        "$description": "Press settle on buttons (translateY 1px). Tightest tap feedback."
      },
      "fast": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Focus-ring outline-offset transition. Hover micro-states."
      },
      "base": {
        "$value": "150ms",
        "$type": "duration",
        "$description": "Button release-bounce, modal exit, dropdown enter, toast exit."
      },
      "moderate": {
        "$value": "200ms",
        "$type": "duration",
        "$description": "Default transition — button hover lift, switch toggle, tab indicator slide, modal enter, toast enter."
      },
      "slow": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Larger reveals, panel slides, page transitions."
      },
      "count-up": {
        "$value": "800ms",
        "$type": "duration",
        "$description": "Number count-up on dashboard load."
      },
      "shimmer": {
        "$value": "1500ms",
        "$type": "duration",
        "$description": "Loading shimmer sweep loop."
      },
      "pulse": {
        "$value": "1800ms",
        "$type": "duration",
        "$description": "StatusDot pulse-ring continuous loop."
      }
    },
    "easing": {
      "default": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "ease-out-expo — Mercury-Stripe register. Default for hover lift, switch, tab indicator, modal enter."
      },
      "in": {
        "$value": "cubic-bezier(0.4, 0, 1, 1)",
        "$type": "cubicBezier",
        "$description": "Press settle, modal/toast exit."
      },
      "out": {
        "$value": "cubic-bezier(0, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Release bounce, dropdown enter, modal enter (alt to exp-out)."
      },
      "inOut": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "StatusDot pulse continuous loop."
      },
      "exp-out": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "Alias for default — exponential-out reads as Mercury cadence."
      }
    }
  }
}
