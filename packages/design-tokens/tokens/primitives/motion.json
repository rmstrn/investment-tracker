{
  "motion": {
    "duration": {
      "fast": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Hover states, taps"
      },
      "base": {
        "$value": "200ms",
        "$type": "duration",
        "$description": "Most transitions, button press"
      },
      "slow": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Page transitions, panel slides"
      },
      "slower": {
        "$value": "500ms",
        "$type": "duration",
        "$description": "Large reveals, modal enter"
      },
      "count-up": {
        "$value": "800ms",
        "$type": "duration",
        "$description": "Number count-up on load"
      },
      "shimmer": {
        "$value": "1500ms",
        "$type": "duration",
        "$description": "Loading shimmer sweep loop"
      }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "inOut": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "spring": {
        "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "$type": "cubicBezier",
        "$description": "Playful confirmations — use sparingly (CTAs, liked, saved)"
      },
      "exp-out": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "Exponential-out — number count-up, hero reveal"
      }
    }
  }
}
