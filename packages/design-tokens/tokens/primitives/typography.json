{
  "font": {
    "family": {
      "sans": {
        "$value": "Geist, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary UI font — Geist (Vercel, OFL). Single sans across display + body + UI per v1.1."
      },
      "mono": {
        "$value": "'Geist Mono', ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', monospace",
        "$type": "fontFamily",
        "$description": "Mono — Geist Mono. Used for eyebrow labels, citation IDs, breadcrumbs, mono metadata."
      }
    },
    "size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "20px", "$type": "dimension" },
      "2xl": { "$value": "24px", "$type": "dimension" },
      "3xl": { "$value": "30px", "$type": "dimension" },
      "4xl": { "$value": "36px", "$type": "dimension" },
      "display-xl": {
        "$value": "72px",
        "$type": "dimension",
        "$description": "Hero total portfolio value (dashboard)"
      },
      "display-lg": {
        "$value": "48px",
        "$type": "dimension",
        "$description": "Page titles, marketing hero, KPI values"
      },
      "display-md": { "$value": "36px", "$type": "dimension", "$description": "Section heroes" },
      "display-sm": {
        "$value": "28px",
        "$type": "dimension",
        "$description": "Sub-heroes, chart titles"
      },
      "heading-lg": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Card titles, section heads"
      },
      "heading-md": { "$value": "18px", "$type": "dimension", "$description": "Sub-sections" },
      "body-lg": { "$value": "16px", "$type": "dimension", "$description": "Primary body, inputs" },
      "body-md": {
        "$value": "14px",
        "$type": "dimension",
        "$description": "Tables, secondary body"
      },
      "body-sm": {
        "$value": "13px",
        "$type": "dimension",
        "$description": "Default body in v1.1, chat bubble body"
      },
      "caption": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Metadata, timestamps, all-caps labels"
      },
      "eyebrow": {
        "$value": "10px",
        "$type": "dimension",
        "$description": "Mono eyebrow labels (PROVEDO REPLIES, eyebrow-mono) — paired with letterSpacing.eyebrow."
      }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": {
        "$value": 700,
        "$type": "fontWeight",
        "$description": "Reserved for emphasis-within-headline only — never paired with color shift (brand lock §13.4)."
      }
    },
    "lineHeight": {
      "none": { "$value": "1.0", "$type": "number", "$description": "display-xl hero, h1 sig" },
      "tight": { "$value": "1.1", "$type": "number", "$description": "display-lg page titles" },
      "snug": { "$value": "1.25", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number", "$description": "Body text default" },
      "relaxed": { "$value": "1.625", "$type": "number" },
      "heading-lg": { "$value": "1.3", "$type": "number" },
      "heading-md": { "$value": "1.4", "$type": "number" },
      "display-md": { "$value": "1.15", "$type": "number" },
      "display-sm": { "$value": "1.2", "$type": "number" },
      "eyebrow": {
        "$value": "1.6",
        "$type": "number",
        "$description": "Mono eyebrow labels (10/16)."
      }
    },
    "letterSpacing": {
      "tightest": {
        "$value": "-0.04em",
        "$type": "dimension",
        "$description": "display-xl hero — wordmark logo"
      },
      "tighter": {
        "$value": "-0.035em",
        "$type": "dimension",
        "$description": "display-lg / h1 / h2 / tabular-xl"
      },
      "tight": { "$value": "-0.03em", "$type": "dimension", "$description": "h2 / h2-modal" },
      "snug": {
        "$value": "-0.025em",
        "$type": "dimension",
        "$description": "h3 / insight-head — section heads"
      },
      "normal": { "$value": "0", "$type": "dimension" },
      "wide": {
        "$value": "0.04em",
        "$type": "dimension",
        "$description": "stage-head .right metadata"
      },
      "caption": {
        "$value": "0.10em",
        "$type": "dimension",
        "$description": "mono-meta — table heads, ds-row-label"
      },
      "eyebrow": {
        "$value": "0.22em",
        "$type": "dimension",
        "$description": "stage / sig / insight / modal eyebrow — mono uppercase"
      },
      "eyebrow-tight": {
        "$value": "0.18em",
        "$type": "dimension",
        "$description": "ds-nav / nav-label — slightly tighter eyebrow"
      }
    }
  }
}
