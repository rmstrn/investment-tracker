      "5": {
        "$value": "{color.ink-ramp.dark.5}",
        "$type": "color",
        "$description": "Sequential ramp 5/7 (dark)."
      },
      "6": {
        "$value": "{color.ink-ramp.dark.6}",
        "$type": "color",
        "$description": "Sequential ramp 6/7 (dark)."
