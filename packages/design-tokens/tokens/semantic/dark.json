    "chart-grid": {
      "$value": "rgba(255, 255, 255, 0.10)",
      "$type": "color"
    },
    "chart-grid-strong": {
      "$value": "rgba(255, 255, 255, 0.18)",
      "$type": "color"
    },
    "chart-axis-label": {
      "$value": "{color.neutral.text-tertiary-dark}",
      "$type": "color"
