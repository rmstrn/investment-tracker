{
  "semantic": {
    "bg": {
      "$value": "{color.cocoa.bg}",
      "$type": "color",
      "$description": "App page background — neutral cool dark. Showcase --bg."
    },
    "card": {
      "$value": "{color.cocoa.card}",
      "$type": "color",
      "$description": "Card / elevated surface — luma-bumped for clear lift over bg. Showcase --card."
    },
    "inset": {
      "$value": "{color.cocoa.inset}",
      "$type": "color",
      "$description": "Depressed surface — darker than card, reads as recessed. Showcase --inset."
    },
    "ink": {
      "$value": "{color.parchment}",
      "$type": "color",
      "$description": "Primary text + primary CTA fill on dark — cream-on-dark flip. Showcase --ink."
    },
    "text-2": {
      "$value": "{color.neutral.text-secondary-dark}",
      "$type": "color",
      "$description": "Secondary text — dark theme. Showcase --text-2."
    },
    "text-3": {
      "$value": "{color.neutral.text-tertiary-dark}",
      "$type": "color",
      "$description": "Tertiary text — dark theme. Showcase --text-3."
    },
    "accent": {
      "$value": "{color.jade.bright}",
      "$type": "color",
      "$description": "Forest-jade lighter — dark theme status accent. Showcase --accent."
    },
    "accent-shadow": {
      "$value": "rgba(92, 154, 133, 0.30)",
      "$type": "color",
      "$description": "Drop-shadow tint for filled-accent — dark theme. Showcase --accent-shadow."
    },
    "accent-glow": {
      "$value": "rgba(92, 154, 133, 0.22)",
      "$type": "color",
      "$description": "Pulse halo + focus glow — dark theme. Showcase --accent-glow."
    },
    "terra": {
      "$value": "{color.terra.bright}",
      "$type": "color",
      "$description": "Bronze red-shifted — drift / danger. Dark theme. Showcase --terra."
    },
    "terra-shadow": {
      "$value": "rgba(189, 106, 85, 0.30)",
      "$type": "color"
    },
    "modal-overlay": {
      "$value": "rgba(0, 0, 0, 0.65)",
      "$type": "color",
      "$description": "Modal backdrop — dark theme."
    },

    "background": {
      "primary": { "$value": "{color.cocoa.bg}", "$type": "color" },
      "secondary": { "$value": "{color.cocoa.inset}", "$type": "color" },
      "tertiary": { "$value": "{color.cocoa.inset}", "$type": "color" },
      "elevated": { "$value": "{color.cocoa.card}", "$type": "color" },
      "inverse": { "$value": "{color.parchment}", "$type": "color" },
      "overlay": { "$value": "rgba(0, 0, 0, 0.65)", "$type": "color" }
    },

    "text": {
      "primary": { "$value": "{color.parchment}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.text-secondary-dark}", "$type": "color" },
      "tertiary": { "$value": "{color.neutral.text-tertiary-dark}", "$type": "color" },
      "muted": { "$value": "{color.neutral.text-tertiary-dark}", "$type": "color" },
      "brand": {
        "$value": "{color.parchment}",
        "$type": "color",
        "$description": "Brand-text = parchment in dark — primary signal is cream-CTA."
      },
      "inverse": { "$value": "{color.cocoa.bg}", "$type": "color" },
      "onBrand": {
        "$value": "{color.cocoa.bg}",
        "$type": "color",
        "$description": "Text on cream-CTA flips to dark bg."
      },
      "onAccent": {
        "$value": "{color.parchment}",
        "$type": "color",
        "$description": "Text on jade — cream for AAA pair."
      }
    },

    "border": {
      "subtle": {
        "$value": "rgba(255, 255, 255, 0.18)",
        "$type": "color",
        "$description": "Card edges, input borders. Showcase --border (dark)."
      },
      "default": { "$value": "rgba(255, 255, 255, 0.18)", "$type": "color" },
      "strong": { "$value": "rgba(255, 255, 255, 0.26)", "$type": "color" },
      "divider": { "$value": "rgba(255, 255, 255, 0.26)", "$type": "color" },
      "focus": { "$value": "{color.jade.bright}", "$type": "color" }
    },

    "state": {
      "positive": {
        "default": { "$value": "{color.jade.bright}", "$type": "color" },
        "subtle": { "$value": "rgba(92, 154, 133, 0.16)", "$type": "color" }
      },
      "negative": {
        "default": { "$value": "{color.terra.bright}", "$type": "color" },
        "subtle": { "$value": "rgba(189, 106, 85, 0.15)", "$type": "color" }
      },
      "warning": {
        "default": { "$value": "{color.terra.bright}", "$type": "color" },
        "subtle": { "$value": "rgba(189, 106, 85, 0.15)", "$type": "color" }
      },
      "info": {
        "default": { "$value": "{color.neutral.text-secondary-dark}", "$type": "color" },
        "subtle": { "$value": "rgba(255, 255, 255, 0.06)", "$type": "color" }
      }
    },

    "portfolio": {
      "gain": {
        "default": { "$value": "{color.jade.bright}", "$type": "color" },
        "subtle": { "$value": "rgba(92, 154, 133, 0.14)", "$type": "color" }
      },
      "loss": {
        "default": { "$value": "{color.terra.bright}", "$type": "color" },
        "subtle": { "$value": "rgba(189, 106, 85, 0.12)", "$type": "color" }
      },
      "neutral": {
        "default": { "$value": "{color.neutral.text-tertiary-dark}", "$type": "color" },
        "subtle": { "$value": "{color.cocoa.inset}", "$type": "color" }
      }
    },

    "interactive": {
      "primary": {
        "$value": "{color.parchment}",
        "$type": "color",
        "$description": "Primary CTA fill on dark — cream extruded."
      },
      "primaryHover": { "$value": "{color.parchment}", "$type": "color" },
      "primaryActive": { "$value": "{color.parchment}", "$type": "color" },
      "secondary": { "$value": "{color.cocoa.card}", "$type": "color" },
      "secondaryHover": { "$value": "rgba(255, 255, 255, 0.04)", "$type": "color" },
      "secondaryActive": { "$value": "rgba(255, 255, 255, 0.08)", "$type": "color" },
      "ghostHover": { "$value": "rgba(255, 255, 255, 0.05)", "$type": "color" },
      "ghostActive": { "$value": "rgba(255, 255, 255, 0.08)", "$type": "color" }
    },

    "shadow": {
      "soft": {
        "$value": "0 1px 3px rgba(0, 0, 0, 0.45)",
        "$type": "shadow",
        "$description": "Dark-theme soft lift — clean depth, no glow."
      },
      "card": {
        "$value": "0 4px 16px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.07)",
        "$type": "shadow",
        "$description": "Dark-theme card lift — top-edge highlight bumped to 0.07 for visible rim."
      },
      "lift": {
        "$value": "0 12px 36px rgba(0, 0, 0, 0.65), inset 0 1px 0 rgba(255, 255, 255, 0.09)",
        "$type": "shadow",
        "$description": "Dark-theme stronger lift — signature / topbar."
      },
      "toast": {
        "$value": "0 10px 28px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.08)",
        "$type": "shadow"
      },
      "modal": {
        "$value": "0 14px 36px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.08)",
        "$type": "shadow"
      },
      "input-inset": {
        "$value": "inset 0 2px 0 rgba(0, 0, 0, 0.4), inset 0 0 0 1px rgba(0, 0, 0, 0.3)",
        "$type": "shadow",
        "$description": "Dark-theme input depressed — deeper top-edge alpha for OLED black."
      },
      "inset-light": {
        "$value": "inset 0 1px 0 rgba(0, 0, 0, 0.3)",
        "$type": "shadow",
        "$description": "Dark-theme light inset for chips, tabs-track, etc."
      },
      "primary-extrude": {
        "$value": "0 2px 6px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08)",
        "$type": "shadow",
        "$description": "Dark-theme primary CTA — restrained, no glow."
      },
      "terra-extrude": {
        "$value": "0 2px 6px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08)",
        "$type": "shadow"
      },
      "chart-card": {
        "$value": "0 6px 20px rgba(0, 0, 0, 0.55), inset 0 1px 0 rgba(255, 255, 255, 0.08), inset 0 -1px 0 rgba(0, 0, 0, 0.35)",
        "$type": "shadow",
        "$description": "ChartCard — dark-theme paper-pressed neumorphism. Top-rim highlight + bottom-rim inset for tactile «sits on table» feel; no warm tint."
      },
      "chart-bar-emboss": {
        "$value": "drop-shadow(0 1px 1.5px rgba(0, 0, 0, 0.45))",
        "$type": "shadow",
        "$description": "Dark-theme SVG drop-shadow filter for chart bars."
      },
      "chart-line-emboss": {
        "$value": "drop-shadow(0 1px 1px rgba(0, 0, 0, 0.4))",
        "$type": "shadow",
        "$description": "Dark-theme SVG drop-shadow filter for chart line strokes."
      }
    },

    "chart-series": {
      "1": { "$value": "{color.chart.dark-1}", "$type": "color" },
      "2": { "$value": "{color.chart.dark-2}", "$type": "color" },
      "3": { "$value": "{color.chart.dark-3}", "$type": "color" },
      "4": { "$value": "{color.chart.dark-4}", "$type": "color" },
      "5": { "$value": "{color.chart.dark-5}", "$type": "color" },
      "6": { "$value": "{color.chart.dark-6}", "$type": "color" },
      "7": { "$value": "{color.chart.dark-7}", "$type": "color" },
      "8": { "$value": "{color.chart.dark-8}", "$type": "color" },
      "9": { "$value": "{color.chart.dark-9}", "$type": "color" },
      "10": { "$value": "{color.chart.dark-10}", "$type": "color" },
      "11": { "$value": "{color.chart.dark-11}", "$type": "color" },
      "12": { "$value": "{color.chart.dark-12}", "$type": "color" }
    },

    "chart-grid": {
      "$value": "rgba(255, 255, 255, 0.10)",
      "$type": "color"
    },
    "chart-grid-strong": {
      "$value": "rgba(255, 255, 255, 0.18)",
      "$type": "color"
    },
    "chart-axis-label": {
      "$value": "{color.neutral.text-tertiary-dark}",
      "$type": "color"
    },
    "chart-tooltip-bg": {
      "$value": "{color.cocoa.card}",
      "$type": "color"
    },
    "chart-tooltip-border": {
      "$value": "rgba(255, 255, 255, 0.18)",
      "$type": "color"
    },
    "chart-cursor": {
      "$value": "rgba(255, 255, 255, 0.24)",
      "$type": "color"
    }
  }
}
