{
  "semantic": {
    "bg": {
      "$value": "{color.cream.bg}",
      "$type": "color",
      "$description": "App page background — cream paper, deepened. Showcase --bg."
    },
    "card": {
      "$value": "{color.cream.card}",
      "$type": "color",
      "$description": "Card / elevated surface. Showcase --card."
    },
    "inset": {
      "$value": "{color.cream.inset}",
      "$type": "color",
      "$description": "Depressed surface (inputs, search wells, chips). Showcase --inset."
    },
    "ink": {
      "$value": "{color.ink}",
      "$type": "color",
      "$description": "Primary text + primary CTA fill. Showcase --ink."
    },
    "text-2": {
      "$value": "{color.neutral.text-secondary-light}",
      "$type": "color",
      "$description": "Secondary text. Showcase --text-2."
    },
    "text-3": {
      "$value": "{color.neutral.text-tertiary-light}",
      "$type": "color",
      "$description": "Tertiary text — metadata, mono labels. Showcase --text-3 (lifted for AA body 4.84:1)."
    },
    "accent": {
      "$value": "{color.jade.deep}",
      "$type": "color",
      "$description": "Forest-jade — status / citation / verified accent. Showcase --accent."
    },
    "accent-shadow": {
      "$value": "rgba(45, 95, 78, 0.32)",
      "$type": "color",
      "$description": "Drop-shadow tint for filled-accent surfaces. Showcase --accent-shadow."
    },
    "accent-glow": {
      "$value": "rgba(45, 95, 78, 0.22)",
      "$type": "color",
      "$description": "Pulse halo + focus glow on inputs. Showcase --accent-glow."
    },
    "terra": {
      "$value": "{color.terra.deep}",
      "$type": "color",
      "$description": "Bronze — drift / negative delta / danger / warning. Showcase --terra."
    },
    "terra-shadow": {
      "$value": "rgba(155, 92, 62, 0.30)",
      "$type": "color",
      "$description": "Drop-shadow tint for filled-terra surfaces."
    },
    "modal-overlay": {
      "$value": "rgba(50, 40, 30, 0.45)",
      "$type": "color",
      "$description": "Modal backdrop — warm-tinted overlay. Showcase --modal-overlay."
    },

    "background": {
      "primary": {
        "$value": "{color.cream.bg}",
        "$type": "color",
        "$description": "Legacy alias for app background → showcase --bg."
      },
      "secondary": {
        "$value": "{color.cream.inset}",
        "$type": "color",
        "$description": "Legacy alias — striped rows / subtle sections."
      },
      "tertiary": {
        "$value": "{color.cream.inset}",
        "$type": "color",
        "$description": "Legacy alias — muted blocks."
      },
      "elevated": {
        "$value": "{color.cream.card}",
        "$type": "color",
        "$description": "Legacy alias — cards / popovers (pair with shadow)."
      },
      "inverse": {
        "$value": "{color.ink}",
        "$type": "color",
        "$description": "Reversed surfaces (toasts, tooltips, footer band)."
      },
      "overlay": {
        "$value": "rgba(50, 40, 30, 0.45)",
        "$type": "color",
        "$description": "Modal backdrop — warm-tinted overlay (matches --modal-overlay)."
      }
    },

    "text": {
      "primary": { "$value": "{color.ink}", "$type": "color" },
      "secondary": { "$value": "{color.neutral.text-secondary-light}", "$type": "color" },
      "tertiary": { "$value": "{color.neutral.text-tertiary-light}", "$type": "color" },
      "muted": {
        "$value": "{color.neutral.text-tertiary-light}",
        "$type": "color",
        "$description": "Muted UI text. AA-compliant (4.84:1 on bg)."
      },
      "brand": {
        "$value": "{color.ink}",
        "$type": "color",
        "$description": "Brand-text now equals ink — primary signal in v1.1 is ink-CTA, not jade."
      },
      "inverse": {
        "$value": "{color.parchment}",
        "$type": "color",
        "$description": "Text on inverse surfaces (toast, on-ink CTA)."
      },
      "onBrand": {
        "$value": "{color.parchment}",
        "$type": "color",
        "$description": "Text placed on ink-filled surface (CTAs)."
      },
      "onAccent": {
        "$value": "{color.static.white}",
        "$type": "color",
        "$description": "Text on filled jade/forest-accent surfaces — 7.50:1 AAA."
      }
    },

    "border": {
      "subtle": {
        "$value": "rgba(20, 20, 20, 0.16)",
        "$type": "color",
        "$description": "Card edges, input borders, toggle borders. Showcase --border."
      },
      "default": { "$value": "rgba(20, 20, 20, 0.16)", "$type": "color" },
      "strong": { "$value": "rgba(20, 20, 20, 0.26)", "$type": "color" },
      "divider": {
        "$value": "rgba(20, 20, 20, 0.26)",
        "$type": "color",
        "$description": "v1.1 dedicated divider token — column separators."
      },
      "focus": { "$value": "{color.jade.deep}", "$type": "color" }
    },

    "state": {
      "positive": {
        "default": { "$value": "{color.jade.deep}", "$type": "color" },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      },
      "negative": {
        "default": { "$value": "{color.terra.deep}", "$type": "color" },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      },
      "warning": {
        "default": {
          "$value": "{color.terra.deep}",
          "$type": "color",
          "$description": "v1.1 collapses warning → bronze."
        },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      },
      "info": {
        "default": {
          "$value": "{color.neutral.text-secondary-light}",
          "$type": "color",
          "$description": "v1.1 info = text-2 (no extra hue)."
        },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      }
    },

    "portfolio": {
      "gain": {
        "default": {
          "$value": "{color.jade.deep}",
          "$type": "color",
          "$description": "Gain — always paired with leading + and iconography."
        },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      },
      "loss": {
        "default": {
          "$value": "{color.terra.deep}",
          "$type": "color",
          "$description": "Loss — always paired with leading − (U+2212) and iconography."
        },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      },
      "neutral": {
        "default": { "$value": "{color.neutral.text-tertiary-light}", "$type": "color" },
        "subtle": { "$value": "{color.cream.inset}", "$type": "color" }
      }
    },

    "interactive": {
      "primary": {
        "$value": "{color.ink}",
        "$type": "color",
        "$description": "Primary CTA fill — ink-extruded."
      },
      "primaryHover": {
        "$value": "{color.ink}",
        "$type": "color",
        "$description": "Hover handled via translateY + shadow lift, not color shift."
      },
      "primaryActive": { "$value": "{color.ink}", "$type": "color" },
      "secondary": { "$value": "{color.cream.card}", "$type": "color" },
      "secondaryHover": { "$value": "rgba(20, 20, 20, 0.03)", "$type": "color" },
      "secondaryActive": { "$value": "rgba(20, 20, 20, 0.06)", "$type": "color" },
      "ghostHover": { "$value": "rgba(20, 20, 20, 0.04)", "$type": "color" },
      "ghostActive": { "$value": "rgba(20, 20, 20, 0.06)", "$type": "color" }
    },

    "shadow": {
      "soft": {
        "$value": "0 1px 3px rgba(20, 20, 20, 0.08), 0 6px 18px rgba(20, 20, 20, 0.06)",
        "$type": "shadow",
        "$description": "Soft lift — swatches, type-rows, dropdown trigger states."
      },
      "card": {
        "$value": "5px 5px 14px rgba(140, 100, 55, 0.14), -3px -3px 10px rgba(255, 250, 240, 0.55), inset 1px 1px 0 rgba(255, 255, 255, 0.5)",
        "$type": "shadow",
        "$description": "Card lift — multi-axis cream-tinted. Default card surface."
      },
      "lift": {
        "$value": "8px 8px 24px rgba(140, 100, 55, 0.18), -3px -3px 12px rgba(255, 250, 240, 0.60), inset 1px 1px 0 rgba(255, 255, 255, 0.6)",
        "$type": "shadow",
        "$description": "Stronger card lift — signature card / topbar / hero ledger."
      },
      "toast": {
        "$value": "6px 10px 28px rgba(120, 80, 40, 0.20), -3px -3px 10px rgba(255, 250, 240, 0.55), inset 1px 1px 0 rgba(255, 255, 255, 0.5)",
        "$type": "shadow",
        "$description": "Toast / floating surfaces sitting on bg (no card scaffold)."
      },
      "modal": {
        "$value": "8px 10px 36px rgba(20, 20, 20, 0.24), -2px -2px 10px rgba(255, 250, 240, 0.7), inset 1px 1px 0 rgba(255, 255, 255, 0.4)",
        "$type": "shadow",
        "$description": "Modal panel above backdrop."
      },
      "input-inset": {
        "$value": "inset 3px 3px 6px rgba(140, 100, 55, 0.14), inset -2px -2px 4px rgba(255, 250, 240, 0.9)",
        "$type": "shadow",
        "$description": "Input depressed slot — text inputs / search ONLY. v1.1 toggles do NOT use this."
      },
      "inset-light": {
        "$value": "inset 1.5px 1.5px 3px rgba(140, 100, 55, 0.10), inset -1px -1px 2px rgba(255, 250, 240, 0.8)",
        "$type": "shadow",
        "$description": "Light inset — chips, citations, tabs-track, btn-icon, info-toast, empty-icon."
      },
      "primary-extrude": {
        "$value": "4px 4px 12px rgba(20, 20, 20, 0.18), -1px -1px 4px rgba(255, 250, 240, 0.6), inset 1px 1px 0 rgba(255, 255, 255, 0.06)",
        "$type": "shadow",
        "$description": "Primary CTA — ink button extruded. v1.1 ink-CTA depth."
      },
      "terra-extrude": {
        "$value": "3px 3px 10px rgba(155, 92, 62, 0.28), -1px -1px 4px rgba(255, 250, 240, 0.5), inset 1px 1px 0 rgba(255, 255, 255, 0.12)",
        "$type": "shadow",
        "$description": "Danger CTA — bronze button extruded."
      }
    }
  }
}
