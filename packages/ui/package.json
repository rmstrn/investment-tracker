{
  "name": "@investment-tracker/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared React UI components for Portfolio (shadcn-style, Tailwind v4, design-tokens-driven).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./charts": {
      "types": "./src/charts/index.ts",
      "default": "./src/charts/index.ts"
    },
    "./charts/lazy": {
      "types": "./src/charts/lazy.ts",
      "default": "./src/charts/lazy.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo node_modules"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@investment-tracker/design-tokens": "workspace:*",
    "@investment-tracker/shared-types": "workspace:*",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "lucide-react": "^0.468.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "axe-core": "^4.11.3",
    "happy-dom": "^15.11.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "^5.7.2",
    "vite": "5.4.21",
    "vitest": "^2.1.8"
  }
}
