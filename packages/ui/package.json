{
  "name": "@investment-tracker/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared React UI components for Portfolio (shadcn-style, Tailwind v4, design-tokens-driven).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "clean": "rm -rf .turbo node_modules"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@investment-tracker/design-tokens": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "^5.7.2"
  }
}
